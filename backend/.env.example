# ============================================
# DATABASE CONFIGURATION
# ============================================
# For local development:
# DATABASE_URL=postgresql://raish:raish@localhost:5432/raish_db

# For Azure VM (docker-compose):
DATABASE_URL=postgresql://raish:your_password@postgres:5432/raish_db
POSTGRES_DB=raish_db
POSTGRES_USER=raish
POSTGRES_PASSWORD=your_secure_password_here

# ============================================
# FASTAPI SECURITY
# ============================================
SECRET_KEY=your_random_secret_key_here_use_openssl_rand_hex_32
ALGORITHM=HS256

# ============================================
# CLOUDFLARE R2 (S3-compatible)
# ============================================
R2_ACCOUNT_ID=your_account_id_here
R2_BUCKET=raish-music
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ============================================
# JIOSAAVN API (Cloudflare Workers deployed)
# ============================================
JIOSAAVN_API_URL=https://jiosaavn-api.YOUR_USERNAME.workers.dev

# ============================================
# CORS & FRONTEND
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production
LOG_LEVEL=INFO
